rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Agent verification documents (ID card, selfie) — private
    match /agents/{agentId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == agentId;
    }

    // Public room listing photos
    match /rooms/{roomId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // General fallback
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
